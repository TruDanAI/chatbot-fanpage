# Shop đang chạy: thư mục shops/<SHOP_ID> (config.js, products.csv, custom-intents.js).
# adult-shop | nem-bui-xa | ...
SHOP_ID=adult-shop

# Gemini mặc định dùng Google Cloud / Vertex AI để trừ vào credits Cloud Console.
# api_key là mode legacy, chỉ bật khi chủ động set GEMINI_PROVIDER=api_key.
GEMINI_PROVIDER=vertex
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=global

# Local Vertex AI: chạy `gcloud auth application-default login` hoặc setup ADC.
# Deploy ngoài Google Cloud: dùng 1 trong 2 biến dưới, không commit file service account JSON.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=base64_of_service_account_json

# Legacy Gemini Developer API / AI Studio. Chỉ cần khi GEMINI_PROVIDER=api_key.
# GEMINI_API_KEY=your_gemini_api_key_here

# Lấy tại: developers.facebook.com → App → Messenger → Access Tokens
FB_PAGE_TOKEN=your_facebook_page_token_here

# Tự đặt một chuỗi ngẫu nhiên (đừng dùng giá trị mặc định public)
FB_VERIFY_TOKEN=please_change_me_to_a_random_string

# Lấy tại: developers.facebook.com → App → Settings → Basic → "App Secret"
# Dùng để xác thực chữ ký webhook (khuyến nghị bật)
FB_APP_SECRET=your_facebook_app_secret_here

# Bật/tắt Gemini fallback. Set false để bot chỉ dùng rule-based, không gọi Gemini.
# USE_GEMINI=false

# Port (Railway/Render tự set, không cần đổi)
PORT=3000

# Base URL public của app để Messenger lấy ảnh sản phẩm/menu
# Ví dụ Railway: https://ten-app.up.railway.app
# Có thể bỏ trống nếu dùng RAILWAY_PUBLIC_DOMAIN hoặc RENDER_EXTERNAL_URL
PUBLIC_BASE_URL=

# Token bí mật để tải danh sách khách qua trình duyệt:
# https://ten-app.up.railway.app/admin/customers.csv?token=your_secret_token
ADMIN_EXPORT_TOKEN=your_long_random_admin_token_here

# (Tuỳ chọn) Thư mục lưu state/lead. Khi dùng Railway Volume, set DATA_DIR bằng mount path.
# Ví dụ nếu Volume mount ở /data thì set: DATA_DIR=/data
# Local có thể bỏ trống để dùng ./data
DATA_DIR=/data

# (Tuỳ chọn) Nhắc giỏ bỏ dở: chỉ nhắc khách đã vào checkout nhưng còn thiếu thông tin.
# Mặc định bật, nhắc sau 20 phút và chỉ nhắc 1 lần cho mỗi draft.
# ABANDONED_CART_REMINDER_ENABLED=true
# ABANDONED_CART_REMINDER_MS=1200000
# ABANDONED_CART_REMINDER_SCAN_MS=60000
# ABANDONED_CART_REMINDER_MAX_AGE_MS=82800000

# (Tuỳ chọn) Web App URL (Google Apps Script doPost) để đẩy lead khi đơn CONFIRMED.
# Không set = không gọi; luồng customers.csv vẫn giữ nguyên.
# JSON body có dedupeKey (SHA-256 hex): trong Script kiểm tra trùng trước khi append hàng.
GOOGLE_SHEET_WEBHOOK_URL=your_google_apps_script_webhook_url_here

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
