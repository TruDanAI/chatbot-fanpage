# Copy file này thành .env ở local hoặc nhập từng biến vào Variables trên Railway/Render.
# Không commit file .env thật vì có Page Token, App Secret, service account và admin token.

# ========== Runtime ==========
# Production bắt buộc FB_APP_SECRET. Local có thể dùng development.
NODE_ENV=production

# Railway/Render thường tự set PORT. Local có thể dùng 3000.
PORT=3000

# Railway thường tự set các biến này. Local có thể để trống.
# RAILWAY_ENVIRONMENT=production
# RAILWAY_ENVIRONMENT_NAME=production
# RAILWAY_GIT_BRANCH=main

# Shop đang chạy: thư mục shops/<SHOP_ID> (config.js, products.csv, custom-intents.js).
# Ví dụ hiện có: adult-shop
SHOP_ID=adult-shop
# ACTIVE_SHOP=adult-shop

# Runtime DB shop config. Staging only until production rollout approved.
MULTI_SHOP_DB_CONFIG_ENABLED=false

# DB runtime live gate. Khi bật, shop DB phải active, lifecycle=live và
# live_enabled=true; thiếu control columns thì runtime fail-closed.
SHOP_LIVE_GATE_ENABLED=false

# Tenant mặc định cho storage/admin/queue. Đừng đổi production nếu chưa có
# migration và kế hoạch tách tenant rõ ràng.
TENANT_ID=default

# Required only when DB-backed runtime must decrypt shop/page credentials.
# Use a long random value and rotate with a planned credential re-encryption path.
# Do not set/change in production without separate env approval.
# CREDENTIAL_MASTER_KEY=change_me_to_64_plus_random_chars

# Local/staging credential seed helper only. Do not commit or print this value.
# Production credential seed needs fresh backup and explicit production DB write approval.
# PAGE_CREDENTIAL_SHOP_ID=adult-shop
# PAGE_CREDENTIAL_TOKEN=facebook_page_token_to_encrypt
# PAGE_CREDENTIAL_PAGE_ID=123456789012345
# CREDENTIAL_KEY_ID=default
# CREDENTIAL_KEY_VERSION=1

# Canary/staging seed helper. Test shop scripts reject raw page id CLI args and
# read this from env instead.
# TEST_SHOP_PAGE_ID=123456789012345
# TEST_SHOP_PAGE_NAME=Test Shop Canary Fanpage
# TEST_SHOP_PAGE_TOKEN=facebook_test_page_token
# TEST_SHOP_FB_APP_SECRET=your_test_app_secret

# Production seed confirmations are script-specific. Set only for an approved
# one-off write, using the exact phrase printed by that script.
# CONFIRM_PRODUCTION_WRITE=exact_script_confirmation_phrase

# Optional runtime admission guard for DB-backed multi-shop rollout.
# When either list is non-empty, resolved shops/pages not in these lists fail closed.
# RUNTIME_ALLOWED_SHOP_IDS is the primary control and must match shops.id.
# RUNTIME_ALLOWED_PAGE_IDS is a post-resolution transition override; the page must
# already exist in active shop_pages, it does not allow unknown pages to fallback.
# RUNTIME_ALLOWED_SHOP_IDS=adult-shop
# RUNTIME_ALLOWED_PAGE_IDS=123456789012345


# ========== Public URL / Media ==========
# Base URL public để Messenger lấy ảnh sản phẩm/menu.
# Railway có thể tự suy ra từ RAILWAY_PUBLIC_DOMAIN, Render từ RENDER_EXTERNAL_URL.
# Nếu ảnh không gửi được, set cố định URL public của app ở đây.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Platform public URL fallbacks. Railway/Render thường tự set.
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# RENDER_EXTERNAL_URL=https://your-app.onrender.com


# ========== Facebook Messenger ==========
# Lấy tại: developers.facebook.com -> App -> Messenger -> Access Tokens
FB_PAGE_TOKEN=your_facebook_page_token_here

# Tự đặt chuỗi random, rồi dùng đúng chuỗi này khi verify webhook trên Meta.
FB_VERIFY_TOKEN=please_change_me_to_a_long_random_verify_token

# Lấy tại: developers.facebook.com -> App -> Settings -> Basic -> App Secret
# Bắt buộc khi NODE_ENV=production.
FB_APP_SECRET=your_facebook_app_secret_here

# App ID dùng cho token-health diagnostics nếu được phê duyệt riêng.
# META_APP_ID=your_meta_app_id
# FB_APP_ID=your_meta_app_id
# META_APP_SECRET=your_meta_app_secret
# META_APP_ACCESS_TOKEN=app_id_pipe_app_secret
# FB_APP_ACCESS_TOKEN=app_id_pipe_app_secret
# PAGE_TOKEN_HEALTH_REQUIRED_PERMISSIONS=pages_messaging

# Optional file-config page allowlist/storage context. DB runtime vẫn phải resolve
# page mapping từ database và không fallback sang Page ID này.
# FB_PAGE_ID=123456789012345
# PAGE_ID=123456789012345

# Non-production vẫn có thể ép bắt buộc FB_APP_SECRET để test sớm.
# REQUIRE_FB_APP_SECRET=true

# Staging smoke không gọi Facebook thật nhưng vẫn chạy trọn webhook flow.
# Production sẽ từ chối khởi động nếu bật biến này.
# MESSENGER_DRY_RUN=true


# ========== Gemini / AI Fallback ==========
# Set false nếu muốn bot chỉ dùng rule-based, không gọi Gemini.
USE_GEMINI=true

# Mặc định dùng Vertex AI. Chỉ đổi sang api_key nếu dùng AI Studio/Developer API.
GEMINI_PROVIDER=vertex
GEMINI_MODEL=gemini-2.5-flash

# Guardrail vận hành: giữ thấp để bot trả lời ngắn, ít lan man.
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=500

# Vertex AI project/location.
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=global
# GOOGLE_PROJECT_ID=your-google-cloud-project-id

# Local Vertex AI: chạy `gcloud auth application-default login` hoặc setup ADC.
# Deploy ngoài Google Cloud: dùng 1 trong 2 biến dưới, ưu tiên BASE64 để tránh lỗi xuống dòng.
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=base64_of_service_account_json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Legacy Gemini Developer API / AI Studio. Chỉ cần khi GEMINI_PROVIDER=api_key.
# GEMINI_PROVIDER=api_key
# GEMINI_API_KEY=your_gemini_api_key_here


# ========== Admin Export / Security ==========
# Token bí mật để tải customers/events/state qua admin endpoints.
# Sau bản hardening, KHÔNG dùng ?token=... trên URL nữa.
# Dùng header: x-admin-token: <ADMIN_EXPORT_TOKEN>
# Hoặc: Authorization: Bearer <ADMIN_EXPORT_TOKEN>
ADMIN_EXPORT_TOKEN=your_64_char_random_admin_token_here

# Optional label cho admin UI badge; Railway/Node env vẫn là nguồn chính.
# ADMIN_ENV=staging

# Principal/role dùng cho admin token hiện tại. Mặc định code là owner để giữ
# tương thích; set cụ thể hơn ở production sau khi đã chốt RBAC.
# ADMIN_PRINCIPAL_ID=legacy-admin
# ADMIN_PRINCIPAL_DISPLAY_NAME=Legacy Admin
# ADMIN_ROLES=owner

# Ghi audit admin vào PostgreSQL. Chỉ bật sau khi schema audit đã apply và
# được xác nhận riêng ở production.
# ADMIN_AUDIT_LOG_ENABLED=true

# Tuỳ chọn: chỉ cho admin endpoints từ các IP này. Bỏ trống nếu IP vận hành hay đổi.
# Ví dụ: ADMIN_IP_ALLOWLIST=1.2.3.4,5.6.7.8
ADMIN_IP_ALLOWLIST=

# Rate limit admin endpoints.
ADMIN_RATE_LIMIT_WINDOW_MS=300000
ADMIN_RATE_LIMIT_MAX=60


# ========== Admin Login / Session ==========
# Optional cho local, bắt buộc nếu muốn dùng /admin/login trên production.
# Nếu bỏ trống, admin vẫn dùng Authorization: Bearer <ADMIN_EXPORT_TOKEN>.
# Production nên dùng chuỗi random 64+ ký tự; đổi biến này sẽ làm session cũ hết hiệu lực.
# SESSION_SECRET=change_me_to_64_plus_random_chars

# Public base URL của admin/app. Dùng để suy ra cookie Secure khi URL là https.
# Production Railway hiện dùng domain public của service.
# ADMIN_PUBLIC_BASE_URL=https://chatbot-fanpage-production.up.railway.app

# Tên cookie session admin. Chỉ đổi nếu cần tránh trùng cookie với app khác cùng domain.
# ADMIN_SESSION_COOKIE_NAME=chatbot_admin_session

# Optional. TTL session admin theo milliseconds; mặc định 8 giờ.
# Giảm TTL sẽ làm session hết hạn nhanh hơn; tăng TTL giữ cookie hợp lệ lâu hơn nếu bị lộ máy.
# ADMIN_SESSION_TTL_MS=28800000

# Optional. Rate limit riêng cho POST /admin/login theo IP, lưu trong memory từng process.
# Production mặc định 10 lần trong 5 phút; tăng nếu admin dùng chung proxy/NAT.
# ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=300000
# ADMIN_LOGIN_RATE_LIMIT_MAX=10


# ========== Admin Image Upload ==========
# Disabled by default. Chỉ bật staging/production sau approval riêng.
ADMIN_IMAGE_UPLOAD_ENABLED=false

# Upload thật yêu cầu Cloudinary URL + folder. Không commit giá trị thật.
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_FOLDER=chatbot-fanpage-staging

# Wizard pre-flight có thể dùng cloud name để báo cấu hình sơ bộ, nhưng upload
# write path vẫn cần CLOUDINARY_URL và CLOUDINARY_FOLDER.
# CLOUDINARY_CLOUD_NAME=cloud_name

# Demo shop credential write unlock. Chỉ dùng staging + dry-run khi operator đã
# xác nhận đúng guardrail.
# DEMO_SHOP_CREDENTIAL_WRITE_ENABLED=false

# Optional upload limits. Mặc định: 5MB, jpeg/png/webp.
# IMAGE_UPLOAD_MAX_BYTES=5242880
# IMAGE_UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp
# IMAGE_UPLOAD_ALLOWED_EXT=.jpg,.jpeg,.png,.webp


# ========== Webhook ==========
# Rate limit webhook theo IP. Nếu page volume cao hoặc Meta retry nhiều, tăng WEBHOOK_RATE_LIMIT_MAX.
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=300

# Durable webhook queue phase 1. Keep false in production until the queue schema,
# worker behavior, and rollback plan have been approved and rolled out.
# Requires PostgreSQL and db/multi-shop-proposal.sql webhook_queue schema.
WEBHOOK_QUEUE_ENABLED=false
WEBHOOK_QUEUE_BATCH_SIZE=10
WEBHOOK_QUEUE_MAX_ATTEMPTS=5
WEBHOOK_QUEUE_RETRY_DELAY_MS=15000
WEBHOOK_QUEUE_WORKER_INTERVAL_MS=1000
# WEBHOOK_QUEUE_WORKER_ID=webhook-worker-1


# ========== Persistence ==========
# Thư mục lưu state/lead/events/outbox.
# Railway Volume mount /data thì set DATA_DIR=/data.
# Local có thể để trống để dùng ./data.
DATA_DIR=/data

# PostgreSQL runtime/admin URL. Không dùng biến này cho schema verifier nếu có
# nguy cơ trỏ production.
# DATABASE_URL=postgres://user:password@host:5432/database
# DATABASE_PUBLIC_URL=postgres://user:password@host:5432/database

# Explicit non-production URLs cho verifier/smoke scripts. Các script này cố ý
# từ chối DATABASE_URL fallback.
# CHATBOT_TEST_DATABASE_URL=postgres://user:password@localhost:5432/chatbot_test
# CHATBOT_STAGING_DATABASE_URL=postgres://user:password@host:5432/chatbot_staging
# CHATBOT_HEALTH_DATABASE_URL=postgres://user:password@host:5432/chatbot_health

# Adapter lưu trữ runtime. Production chỉ được đổi sang postgres sau backup,
# dry-run/apply staging và xác nhận vận hành riêng.
# STORAGE_ADAPTER=file
# STORAGE_ADAPTER=postgres
# ALLOW_PRODUCTION_DB_WRITES=true

# File-to-Postgres migration apply guard. Chỉ set khi chạy script migration
# có backup và approval riêng.
# MIGRATION_TARGET=staging
# PRODUCTION_DB_WRITE_CONFIRMATION=exact_migration_confirmation_phrase


# ========== Conversation / Handoff ==========
# Bot tạm dừng trả lời sau khi nhân viên/page trả lời tay hoặc khách yêu cầu gặp người.
HANDOFF_MS=1800000

# Timeout phiên hội thoại; quá thời gian này draft sẽ được reset/đánh dấu abandoned nếu phù hợp.
SESSION_TIMEOUT_MS=1800000

# Cache tên Facebook user.
FB_PROFILE_CACHE_TTL_MS=604800000

# Khi fallback nhiều lần, bot alert Telegram và có thể tự bật handoff.
FALLBACK_ALERT_THRESHOLD=2
FALLBACK_HANDOFF_THRESHOLD=3
TELEGRAM_ALERT_COOLDOWN_MS=600000


# ========== Abandoned Cart Reminder ==========
# Chỉ nhắc khách đã vào checkout nhưng còn thiếu thông tin.
# Mặc định bật, nhắc sau 20 phút và chỉ nhắc 1 lần cho mỗi draft.
ABANDONED_CART_REMINDER_ENABLED=true
ABANDONED_CART_REMINDER_MS=1200000
ABANDONED_CART_REMINDER_SCAN_MS=60000
ABANDONED_CART_REMINDER_MAX_AGE_MS=82800000

# ========== Engaged Follow-up Reminder ==========
# Tạm tắt mặc định: chỉ bật lại khi đã được xác nhận vận hành riêng.
ENGAGED_FOLLOWUP_REMINDER_ENABLED=false
ENGAGED_FOLLOWUP_REMINDER_MS=7200000
ENGAGED_FOLLOWUP_REMINDER_SCAN_MS=60000
ENGAGED_FOLLOWUP_REMINDER_MAX_AGE_MS=259200000


# ========== Google Sheets ==========
# Web App URL (Google Apps Script doPost) để đẩy lead khi đơn CONFIRMED.
# Bỏ trống = không gọi Sheet; customers.csv vẫn hoạt động.
# JSON body có dedupeKey SHA-256 để Apps Script chống append trùng.
GOOGLE_SHEET_WEBHOOK_URL=


# ========== Telegram Alerts ==========
# Bỏ trống nếu chưa dùng Telegram. Khi set đủ 2 biến, bot sẽ alert lead/handoff/lỗi.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ========== Tests ==========
# Bật console output chi tiết khi chạy npm test.
# TEST_VERBOSE_CONSOLE=false
