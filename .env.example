# Copy file này thành .env ở local hoặc nhập từng biến vào Variables trên Railway/Render.
# Không commit file .env thật vì có Page Token, App Secret, service account và admin token.

# ========== Runtime ==========
# Production bắt buộc FB_APP_SECRET. Local có thể dùng development.
NODE_ENV=production

# Railway/Render thường tự set PORT. Local có thể dùng 3000.
PORT=3000

# Shop đang chạy: thư mục shops/<SHOP_ID> (config.js, products.csv, custom-intents.js).
# Ví dụ hiện có: adult-shop
SHOP_ID=adult-shop
# ACTIVE_SHOP=adult-shop


# ========== Public URL / Media ==========
# Base URL public để Messenger lấy ảnh sản phẩm/menu.
# Railway có thể tự suy ra từ RAILWAY_PUBLIC_DOMAIN, Render từ RENDER_EXTERNAL_URL.
# Nếu ảnh không gửi được, set cố định URL public của app ở đây.
PUBLIC_BASE_URL=https://your-app.up.railway.app


# ========== Facebook Messenger ==========
# Lấy tại: developers.facebook.com -> App -> Messenger -> Access Tokens
FB_PAGE_TOKEN=your_facebook_page_token_here

# Tự đặt chuỗi random, rồi dùng đúng chuỗi này khi verify webhook trên Meta.
FB_VERIFY_TOKEN=please_change_me_to_a_long_random_verify_token

# Lấy tại: developers.facebook.com -> App -> Settings -> Basic -> App Secret
# Bắt buộc khi NODE_ENV=production.
FB_APP_SECRET=your_facebook_app_secret_here

# Non-production vẫn có thể ép bắt buộc FB_APP_SECRET để test sớm.
# REQUIRE_FB_APP_SECRET=true

# Staging smoke không gọi Facebook thật nhưng vẫn chạy trọn webhook flow.
# Production sẽ từ chối khởi động nếu bật biến này.
# MESSENGER_DRY_RUN=true


# ========== Gemini / AI Fallback ==========
# Set false nếu muốn bot chỉ dùng rule-based, không gọi Gemini.
USE_GEMINI=true

# Mặc định dùng Vertex AI. Chỉ đổi sang api_key nếu dùng AI Studio/Developer API.
GEMINI_PROVIDER=vertex
GEMINI_MODEL=gemini-2.5-flash

# Guardrail vận hành: giữ thấp để bot trả lời ngắn, ít lan man.
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=500

# Vertex AI project/location.
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=global
# GOOGLE_PROJECT_ID=your-google-cloud-project-id

# Local Vertex AI: chạy `gcloud auth application-default login` hoặc setup ADC.
# Deploy ngoài Google Cloud: dùng 1 trong 2 biến dưới, ưu tiên BASE64 để tránh lỗi xuống dòng.
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=base64_of_service_account_json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Legacy Gemini Developer API / AI Studio. Chỉ cần khi GEMINI_PROVIDER=api_key.
# GEMINI_PROVIDER=api_key
# GEMINI_API_KEY=your_gemini_api_key_here


# ========== Admin Export / Security ==========
# Token bí mật để tải customers/events/state qua admin endpoints.
# Sau bản hardening, KHÔNG dùng ?token=... trên URL nữa.
# Dùng header: x-admin-token: <ADMIN_EXPORT_TOKEN>
# Hoặc: Authorization: Bearer <ADMIN_EXPORT_TOKEN>
ADMIN_EXPORT_TOKEN=your_64_char_random_admin_token_here

# Principal/role dùng cho admin token hiện tại. Mặc định code là owner để giữ
# tương thích; set cụ thể hơn ở production sau khi đã chốt RBAC.
# ADMIN_PRINCIPAL_ID=legacy-admin
# ADMIN_PRINCIPAL_DISPLAY_NAME=Legacy Admin
# ADMIN_ROLES=owner

# Ghi audit admin vào PostgreSQL. Chỉ bật sau khi schema audit đã apply và
# được xác nhận riêng ở production.
# ADMIN_AUDIT_LOG_ENABLED=true

# Tuỳ chọn: chỉ cho admin endpoints từ các IP này. Bỏ trống nếu IP vận hành hay đổi.
# Ví dụ: ADMIN_IP_ALLOWLIST=1.2.3.4,5.6.7.8
ADMIN_IP_ALLOWLIST=

# Rate limit admin endpoints.
ADMIN_RATE_LIMIT_WINDOW_MS=300000
ADMIN_RATE_LIMIT_MAX=60


# ========== Admin Login / Session ==========
# Optional cho local, bắt buộc nếu muốn dùng /admin/login trên production.
# Nếu bỏ trống, admin vẫn dùng Authorization: Bearer <ADMIN_EXPORT_TOKEN>.
# Production nên dùng chuỗi random 64+ ký tự; đổi biến này sẽ làm session cũ hết hiệu lực.
# SESSION_SECRET=change_me_to_64_plus_random_chars

# Public base URL của admin/app. Dùng để suy ra cookie Secure khi URL là https.
# Production Railway hiện dùng domain public của service.
# ADMIN_PUBLIC_BASE_URL=https://chatbot-fanpage-production.up.railway.app

# Tên cookie session admin. Chỉ đổi nếu cần tránh trùng cookie với app khác cùng domain.
# ADMIN_SESSION_COOKIE_NAME=chatbot_admin_session

# Optional. TTL session admin theo milliseconds; mặc định 8 giờ.
# Giảm TTL sẽ làm session hết hạn nhanh hơn; tăng TTL giữ cookie hợp lệ lâu hơn nếu bị lộ máy.
# ADMIN_SESSION_TTL_MS=28800000

# Rate limit webhook theo IP. Nếu page volume cao hoặc Meta retry nhiều, tăng WEBHOOK_RATE_LIMIT_MAX.
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
WEBHOOK_RATE_LIMIT_MAX=300


# ========== Persistence ==========
# Thư mục lưu state/lead/events/outbox.
# Railway Volume mount /data thì set DATA_DIR=/data.
# Local có thể để trống để dùng ./data.
DATA_DIR=/data

# Adapter lưu trữ runtime. Production chỉ được đổi sang postgres sau backup,
# dry-run/apply staging và xác nhận vận hành riêng.
# STORAGE_ADAPTER=file
# STORAGE_ADAPTER=postgres
# ALLOW_PRODUCTION_DB_WRITES=true


# ========== Conversation / Handoff ==========
# Bot tạm dừng trả lời sau khi nhân viên/page trả lời tay hoặc khách yêu cầu gặp người.
HANDOFF_MS=1800000

# Timeout phiên hội thoại; quá thời gian này draft sẽ được reset/đánh dấu abandoned nếu phù hợp.
SESSION_TIMEOUT_MS=1800000

# Cache tên Facebook user.
FB_PROFILE_CACHE_TTL_MS=604800000

# Khi fallback nhiều lần, bot alert Telegram và có thể tự bật handoff.
FALLBACK_ALERT_THRESHOLD=2
FALLBACK_HANDOFF_THRESHOLD=3
TELEGRAM_ALERT_COOLDOWN_MS=600000


# ========== Abandoned Cart Reminder ==========
# Chỉ nhắc khách đã vào checkout nhưng còn thiếu thông tin.
# Mặc định bật, nhắc sau 20 phút và chỉ nhắc 1 lần cho mỗi draft.
ABANDONED_CART_REMINDER_ENABLED=true
ABANDONED_CART_REMINDER_MS=1200000
ABANDONED_CART_REMINDER_SCAN_MS=60000
ABANDONED_CART_REMINDER_MAX_AGE_MS=82800000


# ========== Google Sheets ==========
# Web App URL (Google Apps Script doPost) để đẩy lead khi đơn CONFIRMED.
# Bỏ trống = không gọi Sheet; customers.csv vẫn hoạt động.
# JSON body có dedupeKey SHA-256 để Apps Script chống append trùng.
GOOGLE_SHEET_WEBHOOK_URL=


# ========== Telegram Alerts ==========
# Bỏ trống nếu chưa dùng Telegram. Khi set đủ 2 biến, bot sẽ alert lead/handoff/lỗi.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
